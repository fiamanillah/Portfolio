---
import { ThemeToggle } from "@/components/theme-toggle"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Shadcn Components</title>
  </head>
  <body>
    <div class="mx-auto w-[95vw] border border-primary/20">
      <div
        class="container mx-auto flex min-h-screen flex-col gap-6 bg-background text-foreground"
      >
        <nav>
          <a href="#">Home</a>
          <a href="#">About</a>
          <a href="#">Contact</a>
          <div>
            <ThemeToggle client:load />
          </div>
        </nav>
        {/* 3. The Animated Horizontal "Shine" Line */}
        <div
          class="pointer-events-none absolute top-1/3 left-0 z-0 h-[1px] w-[200px] animate-scan-horizontal"
        >
          {/* The glowing effect */}
          <div
            class="h-full w-full bg-gradient-to-r from-transparent via-primary to-transparent opacity-80 shadow-[0_0_15px_3px_var(--primary)] blur-[2px]"
          >
          </div>
          {/* The solid core of the laser */}
          <div
            class="absolute inset-0 h-full w-full bg-gradient-to-r from-transparent via-white to-transparent opacity-100"
          >
          </div>
        </div>
        <slot />
      </div>
    </div>
  </body>
</html>

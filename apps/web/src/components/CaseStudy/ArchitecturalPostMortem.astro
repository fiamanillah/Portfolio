---
import CaseStudySectionTitle from "@/components/CaseStudy/CaseStudySectionTitle.astro"

interface PostMortemEntry {
  heading: string
  detail: string
  code?: string
}

interface PostMortemItem {
  title: string
  body?: string
  entries?: PostMortemEntry[]
}

interface Props {
  items: PostMortemItem[]
}

const { items } = Astro.props as Props
---

<section class="space-y-8">
  <CaseStudySectionTitle label="[ SEC_05 // ARCHITECTURAL_POST_MORTEM ]" />
  <div class="grid gap-6 md:grid-cols-2">
    {
      items.map((item, index) => (
        <article class="group relative overflow-hidden border border-border bg-card p-6 transition-all duration-400 hover:border-primary/40 hover:bg-primary/5">
          <!-- Corner brackets -->
          <div class="pointer-events-none absolute left-0 top-0 h-3 w-3 border-l-[1.5px] border-t-[1.5px] border-primary/30 transition-colors duration-400 group-hover:border-primary/70" />
          <div class="pointer-events-none absolute right-0 top-0 h-3 w-3 border-r-[1.5px] border-t-[1.5px] border-primary/30 transition-colors duration-400 group-hover:border-primary/70" />
          <div class="pointer-events-none absolute bottom-0 left-0 h-3 w-3 border-b-[1.5px] border-l-[1.5px] border-primary/30 transition-colors duration-400 group-hover:border-primary/70" />
          <div class="pointer-events-none absolute bottom-0 right-0 h-3 w-3 border-b-[1.5px] border-r-[1.5px] border-primary/30 transition-colors duration-400 group-hover:border-primary/70" />

          <!-- Top colored line -->
          <div
            class={`pointer-events-none absolute inset-x-0 top-0 h-[2px] opacity-70 transition-opacity duration-400 group-hover:opacity-100 ${index % 2 === 0 ? "bg-destructive/60" : "bg-primary/60"}`}
          />
          
          <!-- Background glow -->
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(120%_140%_at_0%_0%,oklch(var(--primary)/0.05),transparent_55%)] opacity-50 transition-opacity duration-400 group-hover:opacity-100" />
          <!-- Scanline overlay on hover -->
          <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(0_0_0/0.015)_2px,oklch(0_0_0/0.015)_4px)] opacity-0 transition-opacity duration-400 group-hover:opacity-100 dark:bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(1_1_1/0.015)_2px,oklch(1_1_1/0.015)_4px)]" />

          <div class="relative z-10 flex items-center gap-3 border-b border-border/50 pb-4 transition-colors duration-400 group-hover:border-primary/30">
            <span
              class={`flex h-6 w-6 shrink-0 items-center justify-center border ${index % 2 === 0 ? "border-destructive/30 bg-destructive/10 text-destructive" : "border-primary/30 bg-primary/10 text-primary"} shadow-sm transition-colors duration-400 group-hover:border-current`}
            >
              {index % 2 === 0 ? (
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 9v4" />
                  <path d="M12 17h.01" />
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                </svg>
              ) : (
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              )}
            </span>
            <h3 class="text-xl font-bold tracking-tight text-foreground transition-colors duration-300 group-hover:text-primary sm:text-2xl">
              {item.title}
            </h3>
          </div>

          <div class="relative z-10 mt-5 space-y-5">
            {(
              item.entries ??
              (item.body ? [{ heading: "Summary", detail: item.body }] : [])
            ).map((entry) => (
              <article class="relative pl-5">
                <!-- Left accent line -->
                <div class="absolute bottom-0 left-0 top-1 w-px bg-border transition-colors duration-400 group-hover:bg-primary/40" />
                <!-- Line notch -->
                <div class="absolute left-0 top-1.5 h-1.5 w-px bg-primary opacity-0 transition-opacity duration-400 group-hover:opacity-100" />
                
                <h4 class="font-mono text-[11px] font-semibold tracking-[0.1em] text-foreground uppercase transition-colors duration-300 group-hover:text-primary/90">
                  // {entry.heading}
                </h4>
                <p class="mt-2 text-[13px] leading-relaxed text-muted-foreground">
                  {entry.detail}
                </p>
                {entry.code && (
                  <code class="mt-3 block border border-border/50 bg-background/50 px-3 py-2 font-mono text-[11px] text-foreground transition-colors duration-400 group-hover:border-primary/20">
                    {entry.code}
                  </code>
                )}
              </article>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

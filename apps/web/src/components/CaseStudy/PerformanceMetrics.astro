---
import CaseStudySectionTitle from "@/components/CaseStudy/CaseStudySectionTitle.astro"

interface Metric {
  value: string
  label: string
}

interface Props {
  metrics: Metric[]
}

const { metrics } = Astro.props as Props
---

<section class="space-y-5">
  <CaseStudySectionTitle label="[ SEC_04 // PERFORMANCE_METRICS ]" />
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    {
      metrics.map((metric) => (
        <article class="border border-border bg-background p-5 text-center shadow-sm">
          <p class="text-3xl font-black tracking-tight text-foreground">
            {metric.value}
          </p>
          <p class="mt-2 text-xs tracking-[0.18em] text-muted-foreground uppercase">
            {metric.label}
          </p>
        </article>
      ))
    }
  </div>
</section>

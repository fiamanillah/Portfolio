---
import {
  InputGroup,
  InputGroupAddon,
  InputGroupInput,
  InputGroupButton,
} from "@workspace/ui/components/input-group"
import { HugeiconsIcon } from "@hugeicons/react"
import {
  ArrowUpRight03Icon,
  Facebook02Icon,
  GithubIcon,
  Linkedin02Icon,
} from "@hugeicons/core-free-icons"
import { Badge } from "@workspace/ui/components/badge"
import { TextScramble } from "@workspace/ui/components/text-scramble"
---

<section
  data-grid-cross
  class="relative flex min-h-[calc(100svh-5rem)] w-full items-center justify-center overflow-hidden py-24"
>
  <!-- Background Effects -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <!-- Ambient Glow -->
    <div
      class="absolute top-1/2 left-1/2 h-125 w-125 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]"
    >
    </div>
  </div>

  <div
    class="z-10 container mx-auto grid grid-cols-1 justify-between gap-12 px-4 lg:grid-cols-2 lg:gap-[30%]"
  >
    <!-- Left Side: Main Content -->
    <div class="flex flex-col justify-center space-y-8">
      <!-- Main Heading -->
      <div class="space-y-4">
        <h1
          class="text-5xl font-black tracking-tighter text-balance text-foreground sm:text-6xl lg:text-7xl"
        >
          Hi, I'm <br />
          <span class="relative inline-block">
            <span class="relative z-10 text-primary">Fi Amanillah</span>
          </span>
        </h1>
        <div
          class="text-lg leading-relaxed font-medium text-balance text-primary sm:text-xl"
        >
          <span class="text-foreground"> I'm a </span>
          <TextScramble
            client:load
            texts={["Developer", "Backend Specialist", "Cloud Engineer"]}
            speed={5000}
            scrambleSpeed={50}
          />
        </div>
        <p
          class="text-lg leading-relaxed font-medium text-balance text-muted-foreground sm:text-xl"
        >
          Junior Full-Stack Developer specializing in <span
            class="text-foreground">robust backend systems</span
          > and <span class="text-foreground">minimalist interfaces</span>. I
          bridge the gap between complex logic and clean design.
        </p>
      </div>

      <!-- Call to Action: Email Input -->
      <div class="w-full max-w-md">
        <InputGroup
          className="h-14 rounded-full border-2 border-primary bg-foreground text-2xl! font-medium text-background"
        >
          <InputGroupInput
            type="email"
            placeholder="Work with me: email@example.com"
          />
          <InputGroupAddon align="inline-end">
            <InputGroupButton
              className="h-10 rounded-full px-4"
              variant={"default"}
            >
              Connect
            </InputGroupButton>
          </InputGroupAddon>
        </InputGroup>
      </div>

      <!-- Secondary Navigation -->
      <div class="flex items-center gap-6">
        <div
          class="flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          <span>Read my story</span>
          <a
            href="/about"
            class="group flex items-center gap-1 text-primary underline-offset-4 hover:underline"
          >
            Portfolio
            <HugeiconsIcon
              icon={ArrowUpRight03Icon}
              className="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            />
          </a>
        </div>
        <div class="h-4 w-px bg-border"></div>
        <a
          href="#work"
          class="text-sm font-medium text-muted-foreground hover:text-foreground"
          >View Projects</a
        >
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-3 pt-2">
        <span
          class="text-[0.5rem] font-semibold tracking-[0.3em] text-muted-foreground uppercase"
        >
          Follow me
        </span>
        <div class="flex items-center gap-3">
          {
            [
              { href: "#", label: "GitHub", icon: GithubIcon },
              { href: "#", label: "LinkedIn", icon: Linkedin02Icon },
              { href: "#", label: "Facebook", icon: Facebook02Icon },
            ].map(({ href, label, icon }) => (
              <a
                href={href}
                aria-label={label}
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-border bg-background text-foreground transition hover:border-primary hover:bg-primary/10 focus:ring-2 focus:ring-primary/30 focus:outline-none"
              >
                <HugeiconsIcon
                  icon={icon}
                  className="size-5"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Right Side: Details About Me -->
    <div class="flex flex-col items-end justify-center space-y-10">
      <!-- Identity Details (Minimalist List) -->
      <div class="flex w-full max-w-md flex-col gap-4 pt-4">
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-[11px] tracking-widest text-muted-foreground uppercase"
            >Location</span
          >
          <span class="text-sm font-semibold tracking-tight text-foreground"
            >Mirpur, Dhaka-1216</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-[11px] tracking-widest text-muted-foreground uppercase"
            >Experience</span
          >
          <span class="text-sm font-semibold tracking-tight text-foreground"
            >1+ Years</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-[11px] tracking-widest text-muted-foreground uppercase"
            >Specialty</span
          >
          <span class="text-sm font-semibold tracking-tight text-foreground"
            >Full-Stack Dev</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-[11px] tracking-widest text-muted-foreground uppercase"
            >Focus</span
          >
          <span class="text-sm font-semibold tracking-tight text-foreground"
            >Backend & Cloud</span
          >
        </div>
      </div>

      <!-- Terminal (Modern macOS Window) -->
      <div
        class="w-full max-w-md overflow-hidden rounded-xl border border-border bg-background/30 shadow-sm backdrop-blur-3xl"
      >
        <!-- Terminal Header -->
        <div
          class="flex items-center gap-1.5 border-b border-border bg-background px-4 py-3"
        >
          <div class="h-2.5 w-2.5 rounded-full bg-rose-500/80"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
        </div>
        <!-- Terminal Body -->
        <div class="p-5 font-mono text-xs leading-relaxed backdrop-blur-3xl">
          <p>
            <span class="text-muted-foreground/60">~/fi $</span>
            <span class="ml-2 font-semibold text-foreground"
              >whoami --verbose</span
            >
          </p>
          <p class="mt-2">
            <span class="text-emerald-500">→</span>
            <span class="ml-2 text-muted-foreground"
              >Junior Full-Stack Developer</span
            >
          </p>
          <p class="mt-1">
            <span class="text-emerald-500">→</span>
            <span class="ml-2 text-muted-foreground"
              >Loves clean code & brutal simplicity</span
            >
          </p>
          <p class="mt-1">
            <span class="text-emerald-500">→</span>
            <span class="ml-2 text-muted-foreground">Currently building: </span>
            <span class="text-foreground">something cool</span>
          </p>
          <p class="mt-2">
            <span class="text-muted-foreground/60">~/fi $</span>
            <span
              class="ml-2 inline-block h-3.5 w-1.5 animate-pulse bg-foreground align-middle"
            ></span>
          </p>
        </div>
      </div>

      <!-- Tech Stack (Floating Badges) -->
      <div class="w-full max-w-md space-y-4">
        <div class="flex items-center justify-end gap-3">
          <div class="h-px w-12 bg-border"></div>
          <span
            class="font-mono text-[11px] tracking-widest whitespace-nowrap text-muted-foreground uppercase"
            >Tech Stack</span
          >
        </div>
        <div class="flex flex-wrap justify-end gap-2.5">
          {
            [
              { name: "React", color: "#61DAFB" },
              { name: "TypeScript", color: "#3178C6" },
              { name: "Node.js", color: "#68A063" },
              { name: "PostgreSQL", color: "#336791" },
              { name: "AWS", color: "#FF9900" },
              { name: "Docker", color: "#2496ED" },
            ].map(({ name, color }) => (
              <Badge
                variant={"outline"}
                className="border-border/40 bg-background/50 py-1 backdrop-blur-sm"
              >
                <span
                  class="mr-2 h-1.5 w-1.5 shrink-0 rounded-full"
                  style={`background:${color}`}
                />
                {name}
              </Badge>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Background Image Handling -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-20 h-full overflow-hidden"
  >
    <!-- Dotted Background -->
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.3)_1px,transparent_1px)] bg-size-[24px_24px] opacity-60"
    >
    </div>
    <!-- Glow Effect -->
    <div
      class="absolute bottom-0 left-1/2 h-[80%] w-[80%] -translate-x-1/2 translate-y-10 bg-primary/15 blur-[100px] sm:w-[60%]"
    >
    </div>
    <img
      src="/fi.png"
      alt="Hero Image"
      class="absolute bottom-0 left-1/2 w-[70%] -translate-x-1/2 object-contain opacity-80 grayscale transition-opacity duration-700 hover:opacity-30 sm:w-[50%]"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-background via-background/0 to-transparent"
    >
    </div>
  </div>
</section>

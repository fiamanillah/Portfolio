---
import {
  InputGroup,
  InputGroupAddon,
  InputGroupInput,
  InputGroupButton,
} from "@workspace/ui/components/input-group"
import { HugeiconsIcon } from "@hugeicons/react"
import {
  ArrowUpRight03Icon,
  Facebook02Icon,
  GithubIcon,
  Linkedin02Icon,
} from "@hugeicons/core-free-icons"
import { Badge } from "@workspace/ui/components/badge"
import { TextScramble } from "@workspace/ui/components/text-scramble"
---

<section
  data-grid-cross
  class="relative flex min-h-[calc(100svh-5rem)] w-full items-center justify-center overflow-hidden py-24"
>
  <!-- Background Effects -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <!-- Ambient Glow -->
    <div
      class="absolute top-1/2 left-1/2 h-125 w-125 -translate-x-1/2 -translate-y-1/2 bg-primary/10 blur-[120px]"
    >
    </div>
  </div>

  <div
    class="z-10 container mx-auto grid grid-cols-1 justify-between gap-12 px-4 lg:grid-cols-2 lg:gap-16 xl:gap-24"
  >
    <!-- Left Side: Main Content -->
    <div class="flex flex-col justify-center space-y-8">
      <!-- Main Heading -->
      <div class="space-y-4">
        <h1
          class="text-4xl font-black tracking-tighter text-balance text-foreground sm:text-5xl lg:text-6xl"
        >
          Hi, I'm <br />
          <span class="relative inline-block">
            <span class="relative z-10 text-primary">Fi Amanillah</span>
          </span>
        </h1>
        <div
          class="text-base leading-relaxed font-medium text-balance text-primary sm:text-lg"
        >
          <span class="text-foreground"> I'm a </span>
          <TextScramble
            client:load
            texts={[
              "Full-Stack Developer",
              "Backend Specialist",
              "DevOps Engineer",
            ]}
            speed={5000}
            scrambleSpeed={50}
          />
        </div>
        <p
          class="text-sm! leading-relaxed font-medium text-balance text-muted-foreground sm:text-base"
        >
          Full-Stack Developer with 1+ year of professional experience building
          scalable MERN stack, Nest.js, and Next.js applications. Specializing
          in <span class="text-foreground">robust backend systems</span> and <span
            class="text-foreground">DevOps automation</span
          >.
        </p>
      </div>

      <div class="w-full max-w-md">
        <InputGroup
          className="h-12 sm:h-14 border-2 border-border bg-foreground text-sm! sm:text-base! md:text-lg! font-medium text-background"
        >
          <InputGroupInput
            type="email"
            placeholder="Work with me: fi@amanillah.com"
          />
          <InputGroupAddon align="inline-end">
            <InputGroupButton className="h-8 sm:h-10 px-3 sm:px-4" variant={"default"}>
              Connect
            </InputGroupButton>
          </InputGroupAddon>
        </InputGroup>
      </div>

      <!-- Secondary Navigation -->
      <div class="flex items-center gap-6">
        <div
          class="flex items-center gap-2 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground sm:text-sm"
        >
          <span>Read my story</span>
          <a
            href="/about"
            class="group flex items-center gap-1 text-primary underline-offset-4 hover:underline"
          >
            Portfolio
            <HugeiconsIcon
              icon={ArrowUpRight03Icon}
              className="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            />
          </a>
        </div>
        <div class="h-4 w-px bg-border"></div>
        <a
          href="#work"
          class="text-xs font-medium text-muted-foreground hover:text-foreground sm:text-sm"
          >View Projects</a
        >
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-3 pt-2">
        <span
          class="text-[10px] font-semibold tracking-[0.2em] text-muted-foreground uppercase sm:text-xs"
        >
          Follow me
        </span>
        <div class="flex items-center gap-3">
          {
            [
              {
                href: "https://github.com/fiamanillah",
                label: "GitHub",
                icon: GithubIcon,
              },
              {
                href: "https://www.linkedin.com/in/fi-amanillah/",
                label: "LinkedIn",
                icon: Linkedin02Icon,
              },
              {
                href: "https://www.facebook.com/fiamanillah.b2",
                label: "Facebook",
                icon: Facebook02Icon,
              },
            ].map(({ href, label, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="inline-flex h-11 w-11 items-center justify-center border border-border bg-background text-foreground transition hover:border-primary hover:bg-primary/10 focus:ring-2 focus:ring-primary/30 focus:outline-none"
              >
                <HugeiconsIcon
                  icon={icon}
                  className="size-5"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Right Side: Details About Me -->
    <div class="flex flex-col items-start lg:items-end justify-center space-y-10">
      <!-- Identity Details (Minimalist List) -->
      <div class="flex w-full max-w-md flex-col gap-4 pt-4">
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase"
            >Location</span
          >
          <span
            class="text-xs font-semibold tracking-tight text-foreground sm:text-sm"
            >Dhaka, Bangladesh</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase"
            >Experience</span
          >
          <span
            class="text-xs font-semibold tracking-tight text-foreground sm:text-sm"
            >1+ Years</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase"
            >Specialty</span
          >
          <span
            class="text-xs font-semibold tracking-tight text-foreground sm:text-sm"
            >Full-Stack Dev</span
          >
        </div>
        <div
          class="flex items-center justify-between border-b border-border pb-3"
        >
          <span
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase"
            >Focus</span
          >
          <span
            class="text-xs font-semibold tracking-tight text-foreground sm:text-sm"
            >Backend & DevOps</span
          >
        </div>
      </div>

      <!-- SSH Connection -->
      <div class="w-full max-w-md space-y-3.5">
        <div class="flex items-center justify-start lg:justify-end gap-3">
          <div class="h-px w-12 bg-border"></div>
          <span
            class="font-mono text-xs tracking-[0.1em] whitespace-nowrap text-muted-foreground uppercase"
            >Live SSH CV</span
          >
        </div>

        <p class="text-left lg:text-right text-xs leading-relaxed text-muted-foreground">
          Access my interactive retro terminal CV directly from your command
          line:
        </p>

        <!-- Command Box -->
        <div
          class="group relative flex items-center justify-between border border-border bg-background/30 p-3.5 pl-4 font-mono text-sm backdrop-blur-md transition-all duration-300 hover:border-primary/50 hover:bg-background/40"
        >
          <!-- Command text -->
          <div
            class="scrollbar-none flex items-center gap-2 overflow-x-auto pr-12 whitespace-nowrap select-all"
          >
            <span class="text-muted-foreground/40 select-none">$</span>
            <span class="font-semibold text-primary">ssh</span>
            <span class="text-muted-foreground">-p 2222</span>
            <span class="text-foreground">amanillah.com</span>
          </div>

          <!-- Copy button overlay -->
          <button
            id="copy-ssh-btn"
            data-copy-text="ssh -p 2222 amanillah.com"
            class="absolute right-2 flex h-8 w-8 cursor-pointer items-center justify-center border border-border bg-background/80 text-muted-foreground transition-all duration-200 hover:scale-105 hover:border-primary/30 hover:text-foreground"
            aria-label="Copy SSH command"
          >
            <!-- Copy Icon -->
            <svg
              id="copy-icon"
              class="size-4 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
              ></path>
            </svg>
            <!-- Success/Check Icon -->
            <svg
              id="check-icon"
              class="hidden size-4 text-emerald-500 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </button>
        </div>

        <div
          class="flex items-center justify-between font-mono text-[10px] text-muted-foreground/50 uppercase"
        >
          <span>🔐 Secure Connection</span>
          <span>No installation needed</span>
        </div>
      </div>

      <!-- Tech Stack (Floating Badges) -->
      <div class="w-full max-w-md space-y-4">
        <div class="flex items-center justify-start lg:justify-end gap-3">
          <div class="h-px w-12 bg-border"></div>
          <span
            class="font-mono text-xs tracking-[0.1em] whitespace-nowrap text-muted-foreground uppercase"
            >Tech Stack</span
          >
        </div>
        <div class="flex flex-wrap justify-start lg:justify-end gap-2.5">
          {
            [
              { name: "React", color: "#61DAFB" },
              { name: "TypeScript", color: "#3178C6" },
              { name: "Node.js", color: "#68A063" },
              { name: "PostgreSQL", color: "#336791" },
              { name: "AWS", color: "#FF9900" },
              { name: "Docker", color: "#2496ED" },
            ].map(({ name, color }) => (
              <Badge
                variant={"outline"}
                className="border-border bg-background/50 py-1 backdrop-blur-sm"
              >
                <span
                  class="mr-2 h-1.5 w-1.5 shrink-0"
                  style={`background:${color}`}
                />
                {name}
              </Badge>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Background Image Handling -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-20 h-full overflow-hidden"
  >
    <!-- Dotted Background -->
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.3)_1px,transparent_1px)] bg-size-[24px_24px] opacity-60"
    >
    </div>
    <!-- Glow Effect -->
    <div
      class="absolute bottom-0 left-1/2 h-[80%] w-[80%] -translate-x-1/2 translate-y-10 bg-primary/15 blur-[100px] sm:w-[60%]"
    >
    </div>
    <img
      src="/fi.png"
      alt="Hero Image"
      class="absolute bottom-0 left-1/2 w-[70%] -translate-x-1/2 object-contain opacity-25 sm:opacity-50 lg:opacity-80 grayscale transition-opacity duration-700 hover:opacity-10 sm:hover:opacity-20 lg:hover:opacity-30 sm:w-[50%]"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-background via-background/0 to-transparent"
    >
    </div>
  </div>
</section>

<script>
  function setupStickyObserver() {
    const cards = document.querySelectorAll(".sticky-card")

    const checkStickyStates = () => {
      cards.forEach((card) => {
        // Parse the exact top property we assigned in the HTML
        const styleAttr = card.getAttribute("style") || ""
        const match = styleAttr.match(/top:\s*([0-9.]+)px/)
        const rect = card.getBoundingClientRect()

        // If we couldn't parse a sticky top value, mark as not stuck and skip
        if (!match) {
          card.setAttribute("data-stuck", "false")
          return
        }

        const stickyTop = parseFloat(match[1])

        // If the card is flush with its sticky top boundary (or past it), mark it as stuck
        // We use <= stickyTop + 1 to account for sub-pixel rendering variations
        if (rect.top <= stickyTop + 1) {
          card.setAttribute("data-stuck", "true")
        } else {
          card.setAttribute("data-stuck", "false")
        }
      })
    }

    // Attach listeners
    window.addEventListener("scroll", checkStickyStates, { passive: true })
    window.addEventListener("resize", checkStickyStates, { passive: true })

    // Check states immediately on load
    checkStickyStates()
  }

  function setupCopySSH() {
    const btn = document.getElementById("copy-ssh-btn")
    if (!btn) return

    const copyText =
      btn.getAttribute("data-copy-text") || "ssh -p 2222 amanillah.com"
    const copyIcon = document.getElementById("copy-icon")
    const checkIcon = document.getElementById("check-icon")

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(copyText)
        if (copyIcon && checkIcon) {
          copyIcon.classList.add("hidden")
          checkIcon.classList.remove("hidden")
          btn.classList.add("border-emerald-500/50", "bg-emerald-500/10")

          setTimeout(() => {
            checkIcon.classList.add("hidden")
            copyIcon.classList.remove("hidden")
            btn.classList.remove("border-emerald-500/50", "bg-emerald-500/10")
          }, 2000)
        }
      } catch (err) {
        console.error("Failed to copy text: ", err)
      }
    })
  }

  // Ensure compatibility with Astro's View Transitions if enabled
  document.addEventListener("astro:page-load", () => {
    setupStickyObserver()
    setupCopySSH()
  })
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      setupStickyObserver()
      setupCopySSH()
    })
  } else {
    setupStickyObserver()
    setupCopySSH()
  }
</script>

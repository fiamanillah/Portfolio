---
import { Badge } from "@workspace/ui/components/badge"

// components/Home/Skills.astro

const skillSections = [
  {
    code: "FRN",
    ordinal: "01",
    suffix: "ST",
    label: "Frontend & Languages",
    badge: "Frontend & Languages",
    items: [
      { title: "HTML / CSS / JS", left: "Core Web", right: "DOM Styling" },
      { title: "Typescript / Go", left: "Strict Mode", right: "Basic Level" },
      { title: "React / Next.js", left: "Core Stack", right: "SSR Ready" },
      {
        title: "Tailwind / Shadcn UI",
        left: "Atomic CSS",
        right: "Systemic Design",
      },
      { title: "Redux / WebSockets", left: "State Mgmt", right: "Realtime" },
    ],
  },
  {
    code: "BKN",
    ordinal: "02",
    suffix: "ND",
    label: "Backend & Data Layer",
    badge: "Backend & Data Layer",
    items: [
      { title: "Node / Express", left: "Runtime", right: "API Design" },
      { title: "Nest.js", left: "Architecture", right: "Scalable" },
      {
        title: "PostgreSQL / MySQL",
        left: "Relational",
        right: "Data Integrity",
      },
      { title: "MongoDB / Redis", left: "NoSQL", right: "Caching Layer" },
      { title: "Prisma / Mongoose", left: "ORMs", right: "Modeling" },
    ],
  },
  {
    code: "OPS",
    ordinal: "03",
    suffix: "RD",
    label: "Operational Flow",
    badge: "Operational Flow",
    items: [
      { title: "Docker / Nginx", left: "Containers", right: "Reverse Proxy" },
      { title: "Linux / VPS", left: "SysAdmin", right: "Self-Managed" },
      { title: "AWS / GCP", left: "Cloud", right: "Infrastructure" },
      { title: "Proxmox / KVM", left: "Hypervisor", right: "Virtualization" },
      {
        title: "RabbitMQ / CI/CD",
        left: "Message Brokers",
        right: "Pipelines",
      },
    ],
  },
]
---

<style>
  /* Scan-line animation for skill rows */
  @keyframes scan-in {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes shimmer {
    0% {
      background-position: -200% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  @keyframes border-flow {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }

  /* Skill row hover lift */
  .skill-row {
    transition:
      transform 200ms ease,
      background 200ms ease,
      border-color 200ms ease;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    cursor: default;
    opacity: 0; /* Hidden by default for intersection observer */
  }

  .skill-row.is-visible {
    animation: scan-in 500ms ease forwards;
  }

  .skill-row:hover {
    transform: translateX(4px);
    border-left-color: oklch(var(--primary) / 60%);
    background: oklch(var(--primary) / 5%);
    border-radius: 2px;
  }

  /* Section column: subtle inner glow on hover */
  .skill-col {
    position: relative;
    transition: background 300ms ease;
  }
  .skill-col::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 40% at 50% 0%,
      oklch(var(--primary) / 8%) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
  }
  .skill-col:hover::before {
    opacity: 1;
  }

  /* Corner brackets */
  .corner-bracket::before,
  .corner-bracket::after,
  .corner-bracket > span::before,
  .corner-bracket > span::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: oklch(var(--border));
    border-style: solid;
    transition:
      width 220ms ease,
      height 220ms ease,
      border-color 220ms ease;
  }
  .corner-bracket::before {
    top: 8px;
    left: 8px;
    border-width: 1.5px 0 0 1.5px;
  }
  .corner-bracket::after {
    top: 8px;
    right: 8px;
    border-width: 1.5px 1.5px 0 0;
  }
  .corner-bracket > span::before {
    bottom: 8px;
    left: 8px;
    border-width: 0 0 1.5px 1.5px;
  }
  .corner-bracket > span::after {
    bottom: 8px;
    right: 8px;
    border-width: 0 1.5px 1.5px 0;
  }
  .skill-col:hover .corner-bracket::before,
  .skill-col:hover .corner-bracket::after,
  .skill-col:hover .corner-bracket > span::before,
  .skill-col:hover .corner-bracket > span::after {
    width: 14px;
    height: 14px;
    border-color: oklch(var(--primary) / 70%);
  }

  /* Animated accent bar under section header */
  .accent-bar {
    position: relative;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--primary) / 40%),
      transparent
    );
    animation: border-flow 3s ease-in-out infinite;
  }

  /* Section glow blobs */
  .glow-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 500ms ease;
  }
  .skill-col:hover .glow-blob {
    opacity: 1;
  }
</style>

<section
  id="skills"
  data-grid-cross
  class="relative z-10 container mx-auto border-b"
>
  <div class="bg-background/40 shadow-sm backdrop-blur-3xl">
    <!-- Top Header Section -->
    <div class="relative overflow-hidden border-b border-border text-center">
      <!-- Background Pattern (diagonal stripes themed to site palette) -->
      <div
        class="diagonal-stripes pointer-events-none absolute inset-0 -z-10 bg-background"
        aria-hidden="true"
      >
      </div>

      <!-- Subtle ambient glow in header -->
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        aria-hidden="true"
      >
        <div
          class="absolute top-1/2 left-1/2 h-40 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[80px]"
        >
        </div>
      </div>

      <div class="relative z-10 py-8">
        <p
          class="mb-4 pt-6 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase"
        >
          Practical tools, systems, and workflows I use to build products
        </p>
        <h1 class="mb-4 font-black tracking-tighter text-foreground italic">
          Skills <span class="text-primary"> & </span> Stack
        </h1>
        <p
          class="mb-2 text-[11px] font-semibold tracking-[0.15em] text-foreground uppercase"
        >
          Frontend, backend, and infrastructure
        </p>

        <!-- Animated accent bar -->
        <div class="accent-bar mx-auto mb-6 w-24"></div>
      </div>
    </div>

    <!-- 3-Column Grid -->
    <div
      class="grid grid-cols-1 divide-y divide-border md:grid-cols-3 md:divide-x md:divide-y-0"
    >
      {
        skillSections.map((section, sectionIdx) => (
          <div class="skill-col corner-bracket relative flex flex-col p-8 md:p-10">
            {/* Corner bracket span wrapper */}
            <span aria-hidden="true" />

            {/* Glow blob — unique position per column */}
            <div
              class="glow-blob"
              style={`
                width: 160px; height: 160px;
                top: ${sectionIdx === 1 ? "30%" : "10%"};
                left: ${sectionIdx === 0 ? "10%" : sectionIdx === 1 ? "30%" : "50%"};
                background: oklch(var(--primary) / 12%);
              `}
            />

            {/* Section header */}
            <div class="mb-12">
              <h3 class="flex items-start gap-1 text-5xl tracking-tighter text-foreground">
                <span>{section.code}</span>
                {"  "}
                <span class="mt-1.5 font-mono text-lg tracking-normal text-foreground">
                  {section.ordinal}
                  <sup class="text-[10px]">{section.suffix}</sup>
                </span>
              </h3>
              <div class="mt-2 flex items-center gap-2">
                <Badge> {section.badge} </Badge>
              </div>

              {/* Thin separator under badge */}
              <div class="mt-4 h-px bg-gradient-to-r from-primary/30 via-primary/10 to-transparent" />
            </div>

            {/* Skill rows */}
            <div class="space-y-6">
              {section.items.map((item, itemIdx) => (
                <div
                  class="skill-row group/row"
                  style={`animation-delay: ${sectionIdx * 100 + itemIdx * 50}ms;`}
                >
                  <div class="flex items-start justify-between gap-2">
                    <h4 class="text-xl font-bold tracking-tight text-foreground uppercase transition-colors duration-200 group-hover/row:text-primary">
                      {item.title}
                    </h4>
                    {/* Right-side arrow indicator */}
                    <span
                      class="mt-1.5 font-mono text-[9px] text-primary/0 transition-all duration-200 group-hover/row:text-primary/70"
                      aria-hidden="true"
                    >
                      →
                    </span>
                  </div>
                  <div class="mt-1.5 flex items-center gap-2">
                    <span class="font-mono text-[9px] tracking-widest text-muted-foreground uppercase">
                      {item.left}
                    </span>
                    <span class="h-1 w-0.5 rounded-full bg-muted-foreground/30" />
                    <span class="font-mono text-[9px] tracking-widest text-muted-foreground uppercase">
                      {item.right}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Footer Bar 1 -->
    <div
      class="relative flex flex-col items-center justify-between gap-2 overflow-hidden border-t border-b border-border px-6 py-4 font-mono text-[9px] tracking-widest text-muted-foreground uppercase md:flex-row"
    >
      {/* Shimmer line across footer */}
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent opacity-60"
        aria-hidden="true"
      >
      </div>
      <span class="flex items-center gap-2">
        Resident Engineer: [Fi_Amanillah]
      </span>
      <span>Vrs.2026.05 / Updated: May</span>
    </div>

    <!-- Footer Bar 2 -->
    <div
      class="my-1 flex flex-col items-center justify-between gap-2 px-6 py-4 font-mono text-[9px] tracking-widest text-muted-foreground uppercase md:flex-row"
    >
      <span>Remote Sessions. Global Coverage. Index 101.</span>
      <span class="flex items-center gap-1.5">
        Nearest Node:
        <span class="text-primary">[Dhaka_BD]</span>
      </span>
    </div>
  </div>
</section>

<script>
  function setupSkillsObserver() {
    const rows = document.querySelectorAll(".skill-row")

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible")
            // Once animated, we don't need to observe it anymore
            observer.unobserve(entry.target)
          }
        })
      },
      {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px", // Trigger slightly before it's fully in view
      }
    )

    rows.forEach((row) => observer.observe(row))
  }

  // Ensure compatibility with Astro's View Transitions
  document.addEventListener("astro:page-load", setupSkillsObserver)

  // Initial run
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupSkillsObserver)
  } else {
    setupSkillsObserver()
  }
</script>

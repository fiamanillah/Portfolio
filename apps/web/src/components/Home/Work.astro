---
import { Badge } from "@workspace/ui/components/badge"
import { Button } from "@workspace/ui/components/button"
import { Icon } from "astro-icon/components"

// components/Home/Work.astro

const projects = [
  {
    title: "ASK SAM",
    description:
      "AI intelligence module utilizing NLP for care operations monitoring and automated compliance detection.",
    role: "Backend Architecture",
    impact: "Automated manual compliance checks processing.",
    tech: ["Node", "PostgreSQL", "Python", "NLP"],
    links: {
      live: "https://asksam.live",
      github: "https://github.com/...",
      caseStudy: "#",
    },
    img: "/assets/images/project1.png",
    index: "01",
    status: "Live",
    year: "2024",
  },
  {
    title: "VertiAccess Portal",
    description:
      "Multi-sided marketplace facilitating seamless booking and payment modules for drone and flight operators.",
    role: "Full-Stack Developer",
    impact:
      "Engineered robust subscription logic and secure transaction pipelines.",
    tech: ["Next.js", "TypeScript", "PostgreSQL", "Docker"],
    links: {
      live: "https://vertiaccess.com",
      github: null,
      caseStudy: "#",
    },
    img: "/assets/images/project2.png",
    index: "02",
    status: "Live",
    year: "2024",
  },
  {
    title: "Automated Content Pipeline",
    description:
      "Serverless workflow architecture aggregating dynamic media content into published articles.",
    role: "Integration Engineer",
    impact: "Eliminated manual content entry bottlenecks.",
    tech: ["n8n", "Gemini 2.5 Flash", "WordPress", "Zapier"],
    links: {
      live: "#",
      github: "#",
      caseStudy: "#",
    },
    img: "/assets/images/project3.png",
    index: "03",
    status: "Shipped",
    year: "2023",
  },
  {
    title: "CyberNark",
    description: "Scalable backend infrastructure and data management system.",
    role: "Lead Developer",
    impact: "Deployed on self-managed VPS for optimized resource utilization.",
    tech: ["MERN", "Docker", "Hostinger VPS"],
    links: {
      live: "#",
      github: "#",
      caseStudy: "#",
    },
    img: "/assets/images/project3.png",
    index: "04",
    status: "Deployed",
    year: "2023",
  },
]

const CARD_HEADER_HEIGHT = 50 // px
const BASE_TOP_OFFSET = 72
---

<section id="work" class="relative z-10 mx-auto">
  <!-- Header -->
  <div class="relative overflow-hidden text-center">
    <!-- Background Pattern (diagonal stripes themed to site palette) -->
    <div
      class="diagonal-stripes pointer-events-none absolute inset-0 z-10 bg-background"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 py-8">
      <p class="mb-2 text-sm! text-muted-foreground uppercase">
        Selected projects and case studies
      </p>

      <h1
        class="flex items-center justify-center gap-3 font-black tracking-tighter text-foreground"
      >
        <span>Work</span>
        <span class="text-primary">/</span>
        <span class="mt-1 flex flex-col items-start text-left leading-none">
          <span
            class="text-xl font-bold tracking-widest text-foreground uppercase"
            >Project</span
          >
          <span
            class="mt-0.5 text-sm font-semibold tracking-tight text-muted-foreground"
            >Showcase</span
          >
        </span>
      </h1>

      <p class="mx-auto mt-4">
        Production-ready systems, tooling and integrations that demonstrate
        engineering approach and impact.
      </p>
      <!--  Accent bar -->
      <div class="accent-bar mx-auto mb-6 w-60"></div>
    </div>
  </div>

  <!-- Stack Container -->
  <div class="relative flex flex-col gap-12">
    {
      projects.map((p, i) => (
        <article
          class={`sticky-card group sticky flex flex-col border-b border-border bg-background transition-all duration-250 hover:shadow-[0_0_0_1px_oklch(var(--primary)/20%),0_8px_32px_-8px_oklch(var(--primary)/12%)] ${
            i > 0 ? " origin-top" : ""
          }`}
          style={`top: ${BASE_TOP_OFFSET + i * CARD_HEADER_HEIGHT}px; z-index: ${10 + i};`}
          data-stuck="false"
        >
          {/* Corner brackets */}
          <div class="pointer-events-none absolute top-2 left-2 z-10 h-4 w-4 border-t-[1.5px] border-l-[1.5px] border-border transition-all duration-220 group-hover:h-5 group-hover:w-5 group-hover:border-[oklch(var(--primary)/70%)]" />
          <div class="pointer-events-none absolute top-2 right-2 z-10 h-4 w-4 border-t-[1.5px] border-r-[1.5px] border-border transition-all duration-220 group-hover:h-5 group-hover:w-5 group-hover:border-[oklch(var(--primary)/70%)]" />
          <div class="pointer-events-none absolute bottom-2 left-2 z-10 h-4 w-4 border-b-[1.5px] border-l-[1.5px] border-border transition-all duration-220 group-hover:h-5 group-hover:w-5 group-hover:border-[oklch(var(--primary)/70%)]" />
          <div class="pointer-events-none absolute right-2 bottom-2 z-10 h-4 w-4 border-r-[1.5px] border-b-[1.5px] border-border transition-all duration-220 group-hover:h-5 group-hover:w-5 group-hover:border-[oklch(var(--primary)/70%)]" />

          {/* Card header */}
          <div
            class="flex items-start justify-between gap-6 border-t px-4 py-3"
            style={`height: ${CARD_HEADER_HEIGHT}px;`}
          >
            <div class="flex min-w-0 flex-1 items-center gap-3">
              {/* Accent index */}
              <span class="font-bold tracking-[0.2em] text-muted-foreground tabular-nums transition-colors duration-200 group-hover:text-primary">
                {p.index}
              </span>

              <h3 class="truncate leading-snug font-black tracking-tight text-primary transition-all duration-300 group-data-[stuck=true]:text-2xl group-data-[stuck=true]:text-foreground">
                {p.title}
              </h3>
            </div>

            <div class="flex shrink-0 items-center gap-2">
              {/* Year label */}
              <span class="hidden tracking-widest text-muted-foreground sm:block">
                {p.year}
              </span>

              <a href={p.links.live} target="_blank" rel="noopener noreferrer">
                <Button variant={"outline"} size={"sm"}>
                  Live
                  <span>↗</span>
                </Button>
              </a>
              {p.links.github && (
                <a
                  href={p.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Button variant={"outline"} size={"sm"}>
                    Code
                    <span>↗</span>
                  </Button>
                </a>
              )}
            </div>
          </div>

          {/* Card body */}
          <div class="grid gap-4 border-border px-5 py-4 lg:grid-cols-[minmax(0,1fr)_minmax(280px,1fr)] lg:items-stretch">
            <div class="flex flex-col justify-between gap-4">
              <div class="flex flex-wrap gap-1.5">
                <div class="flex flex-col gap-2">
                  {/* Tech badges */}
                  <div class="flex flex-wrap gap-1">
                    {p.tech.map((t) => (
                      <Badge key={t} variant={"outline"}>
                        {t}
                      </Badge>
                    ))}
                  </div>

                  {/* Description */}
                  <div>
                    <p class="leading-relaxed">{p.description}</p>
                  </div>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-1">
                {/* Role / Impact panel */}
                <div class="grid gap-3 border border-border bg-muted/20 p-3 transition-all duration-250">
                  <div class="flex items-start gap-2.5">
                    <Icon
                      name="oui:app-users-roles"
                      class="mt-0.5 size-5 shrink-0 text-primary"
                    />
                    <div class="min-w-0">
                      <span class="text-[0.7rem] tracking-[0.18em] text-muted-foreground uppercase">
                        Role
                      </span>
                      <p class="mt-1 text-sm leading-snug font-medium text-foreground">
                        {p.role}
                      </p>
                    </div>
                  </div>

                  <div class="h-px bg-border" />

                  <div class="flex items-start gap-2.5">
                    <Icon
                      name="mdi:chart-line-variant"
                      class="mt-0.5 size-5 shrink-0 text-primary"
                    />
                    <div class="min-w-0">
                      <p class="text-[0.7rem] tracking-[0.18em] text-muted-foreground uppercase">
                        Impact
                      </p>
                      <p class="mt-1 text-sm leading-snug font-medium text-foreground">
                        {p.impact}
                      </p>
                    </div>
                  </div>
                </div>

                {/* CTA Buttons */}
                <div class="flex flex-wrap gap-2 pt-1">
                  <a
                    href={p.links.live}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Button>
                      Visit site
                      <span>↗</span>
                    </Button>
                  </a>
                  {p.links.caseStudy && (
                    <a
                      href={p.links.caseStudy}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <Button variant={"secondary"}>
                        Case study
                        <span>↗</span>
                      </Button>
                    </a>
                  )}
                </div>
              </div>
            </div>

            {/* Project Image */}
            <div class="relative aspect-video w-full overflow-hidden rounded-lg border border-border before:pointer-events-none before:absolute before:inset-0 before:z-10 before:bg-[linear-gradient(105deg,transparent_40%,oklch(var(--primary)/8%)_50%,transparent_60%)] before:bg-size-[200%_100%] before:transition-all before:duration-600 after:pointer-events-none after:absolute after:inset-0 after:bg-[repeating-linear-gradient(0deg,transparent,transparent_3px,rgba(0,0,0,0.04)_3px,rgba(0,0,0,0.04)_4px)] after:opacity-60 after:transition-opacity after:duration-400 group-hover:after:opacity-0 group-data-[stuck=true]:after:opacity-0 hover:before:bg-position-[-100%_0]">
              <img
                src={p.img}
                alt={p.title}
                class="h-full w-full object-cover grayscale transition duration-700 group-hover:grayscale-0 group-data-[stuck=true]:grayscale-0"
              />

              {/* Bottom-left image label */}
              <div class="absolute right-0 bottom-0 left-0 flex items-end justify-between bg-linear-to-t from-black/50 to-transparent px-3 py-2 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <span class="text-[9px] font-bold tracking-widest text-white/80 uppercase">
                  {p.title}
                </span>
                <span class="text-[9px] tracking-wider text-white/50">
                  {p.index} / 04
                </span>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<!-- Script to calculate scroll positions and detect if a card is currently stuck -->
<script>
  function setupStickyObserver() {
    const cards = document.querySelectorAll(".sticky-card")

    const checkStickyStates = () => {
      cards.forEach((card) => {
        // Parse the exact top property we assigned in the HTML
        const styleAttr = card.getAttribute("style") || ""
        const match = styleAttr.match(/top:\s*([0-9.]+)px/)
        const rect = card.getBoundingClientRect()

        // If we couldn't parse a sticky top value, mark as not stuck and skip
        if (!match) {
          card.setAttribute("data-stuck", "false")
          return
        }

        const stickyTop = parseFloat(match[1])

        // If the card is flush with its sticky top boundary (or past it), mark it as stuck
        // We use <= stickyTop + 1 to account for sub-pixel rendering variations
        if (rect.top <= stickyTop + 1) {
          card.setAttribute("data-stuck", "true")
        } else {
          card.setAttribute("data-stuck", "false")
        }
      })
    }

    // Attach listeners
    window.addEventListener("scroll", checkStickyStates, { passive: true })
    window.addEventListener("resize", checkStickyStates, { passive: true })

    // Check states immediately on load
    checkStickyStates()
  }

  // Ensure compatibility with Astro's View Transitions if enabled
  document.addEventListener("astro:page-load", setupStickyObserver)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupStickyObserver)
  } else {
    setupStickyObserver()
  }
</script>

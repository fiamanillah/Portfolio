---
import { Button } from "@workspace/ui/components/button"

const experiences = [
  {
    year: "2023",
    period: "PRESENT // 18 MO",
    company: "TechCorp Inc.",
    role: "SENIOR SOFTWARE ENGINEER",
    title: ["SENIOR SOFTWARE", "ENGINEER"],
    location: "San Francisco, CA · Remote",
    type: "Full-Time",
    description:
      "Led the architectural redesign of the core platform, increasing system throughput by 40%. Owned end-to-end delivery of three major product releases and established engineering best practices adopted company-wide.",
    highlights: [
      "Reduced API latency by 40% via caching & query optimization",
      "Mentored 4 junior engineers through structured growth plans",
      "Shipped 3 major releases with zero critical production incidents",
      "Architected microservices migration from monolith",
    ],
    technologies: [
      "TypeScript",
      "React",
      "Node.js",
      "AWS",
      "PostgreSQL",
      "Redis",
      "Docker",
      "GraphQL",
    ],
    stats: [
      { label: "Performance Gain", value: "40%" },
      { label: "Engineers Mentored", value: "4" },
      { label: "Releases Shipped", value: "3" },
    ],
    learned:
      "Learned how to balance technical debt reduction with feature velocity in a high-growth environment.",
  },
  {
    year: "2021",
    period: "2023 // 24 MO",
    company: "DevStudio Ltd.",
    role: "FULL STACK DEVELOPER",
    title: ["FULL STACK", "DEVELOPER"],
    location: "New York, NY · Hybrid",
    type: "Full-Time",
    description:
      "Built and maintained production-grade web applications serving 200k+ monthly users. Designed and implemented CI/CD pipelines that cut deployment time by 60%, and led the migration to a modern React frontend.",
    highlights: [
      "Cut deployment pipeline time from 45 min → 18 min",
      "Migrated legacy jQuery app to React 18 with zero downtime",
      "Integrated Stripe payments processing $2M+ monthly",
      "Built internal analytics dashboard used by 3 teams",
    ],
    technologies: [
      "JavaScript",
      "Next.js",
      "PostgreSQL",
      "Stripe",
      "GitHub Actions",
      "Vercel",
      "Prisma",
      "Tailwind",
    ],
    stats: [
      { label: "Deployment Speedup", value: "60%" },
      { label: "Monthly Users", value: "200K" },
      { label: "Revenue Processed", value: "$2M+" },
    ],
    learned:
      "Mastered the art of incremental migrations — rewriting systems in production without disrupting users.",
  },
  {
    year: "2020",
    period: "2021 // 12 MO",
    company: "LaunchPad Startup",
    role: "JUNIOR DEVELOPER",
    title: ["JUNIOR", "DEVELOPER"],
    location: "Austin, TX · On-Site",
    type: "Full-Time",
    description:
      "Contributed to a fast-moving startup building a SaaS product for the EdTech space. Delivered responsive UI components, collaborated closely with designers, and contributed to 2 open-source libraries.",
    highlights: [
      "Shipped 20+ reusable UI components to the design system",
      "Contributed to 2 open-source Vue.js plugins (800+ GitHub stars)",
      "Reduced bundle size by 35% through code splitting",
      "Achieved 95+ Lighthouse score across all landing pages",
    ],
    technologies: [
      "HTML/CSS",
      "Vue.js",
      "Firebase",
      "Figma",
      "Webpack",
      "Jest",
      "Sass",
      "PWA",
    ],
    stats: [
      { label: "Components Built", value: "20+" },
      { label: "Bundle Size Reduction", value: "35%" },
      { label: "Lighthouse Score", value: "95+" },
    ],
    learned:
      "Developed a deep appreciation for design systems and how great component architecture scales with the product.",
  },
]

const totalYears = 5
const totalCompanies = experiences.length
const totalTech = [...new Set(experiences.flatMap((e) => e.technologies))]
  .length
---

<section
  data-grid-cross
  class="relative container mx-auto flex items-center justify-center overflow-clip py-px"
>
  <div class="w-full">
    <div class="bg-background/40 shadow-sm backdrop-blur-3xl">
      <!-- Top Header Section -->
      <div class="border-b border-border text-center">
        <p
          class="mb-4 pt-6 text-[10px] tracking-[0.2em] text-muted-foreground uppercase"
        >
          A brief overview of my professional journey, highlighting key roles,
          projects, and achievements that have shaped my career in software
          development.
        </p>
        <h1 class="mb-4 font-black tracking-tighter text-foreground italic">
          Professional <span class="font-bold text-primary">History</span>
        </h1>
        <p
          class="mb-6 text-[11px] font-semibold tracking-[0.15em] text-foreground uppercase"
        >
          The places I've worked, the projects I've built, and the impact I've
          made
        </p>

        <!-- Summary Stats Bar -->
        <div
          class="grid grid-cols-3 divide-x divide-border border-t border-border"
        >
          <div class="group flex flex-col items-center gap-1 py-5">
            <span
              class="text-3xl font-black tracking-tighter text-primary tabular-nums"
              >{totalYears}+</span
            >
            <span
              class="text-[9px] font-semibold tracking-[0.2em] text-muted-foreground uppercase"
              >Years Experience</span
            >
          </div>
          <div class="group flex flex-col items-center gap-1 py-5">
            <span
              class="text-3xl font-black tracking-tighter text-primary tabular-nums"
              >{totalCompanies}</span
            >
            <span
              class="text-[9px] font-semibold tracking-[0.2em] text-muted-foreground uppercase"
              >Companies</span
            >
          </div>
          <div class="group flex flex-col items-center gap-1 py-5">
            <span
              class="text-3xl font-black tracking-tighter text-primary tabular-nums"
              >{totalTech}+</span
            >
            <span
              class="text-[9px] font-semibold tracking-[0.2em] text-muted-foreground uppercase"
              >Technologies</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Timeline Grid -->
    <div class="flex w-full border-x border-b border-border bg-card">
      <!-- Vertical Label -->
      <div class="group relative hidden w-20 shrink-0 border-r border-border md:block">
        <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(0_0_0/0.015)_2px,oklch(0_0_0/0.015)_4px)] opacity-0 transition-opacity duration-400 group-hover:opacity-100 dark:bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(1_1_1/0.015)_2px,oklch(1_1_1/0.015)_4px)]" />
        
        <div class="sticky top-0 flex h-screen max-h-[100vh] items-center justify-center">
          <h3 class="inline-block origin-center -rotate-90 whitespace-nowrap font-mono text-4xl font-bold tracking-widest text-muted-foreground/30 uppercase transition-colors duration-400 group-hover:text-primary/20">
            TRACK_RECORD
          </h3>
        </div>
      </div>

      <!-- Experiences -->
      <div class="relative w-full overflow-hidden">
        <!-- Blueprint Background -->
        <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,oklch(var(--border)/0.5)_1px,transparent_1px),linear-gradient(to_bottom,oklch(var(--border)/0.5)_1px,transparent_1px)] bg-[size:40px_40px] opacity-20" />

        <div class="relative z-10 flex flex-col">
          {
            experiences.map((exp, index) => (
              <article class={`group relative flex flex-col border-border bg-background/50 backdrop-blur-sm transition-all duration-400 hover:bg-primary/5 md:flex-row ${index !== experiences.length - 1 ? 'border-b' : ''}`}>
                
                <!-- Left Column: Dates & Stats -->
                <div class="flex w-full flex-row justify-between border-b border-border p-6 md:w-1/4 md:flex-col md:border-r md:border-b-0 md:p-8 lg:w-[25%] xl:w-[22%]">
                  <div class="flex flex-col gap-1">
                    <h3 class="text-5xl font-black tracking-tighter text-foreground transition-colors duration-400 group-hover:text-primary group-hover:drop-shadow-[0_0_8px_oklch(var(--primary)/0.5)] md:text-6xl xl:text-7xl">
                      {exp.year}
                    </h3>
                    <div class="mt-2 h-px w-8 bg-primary/40 transition-all duration-400 group-hover:w-12 group-hover:bg-primary" />
                    <p class="mt-3 font-mono text-[9px] tracking-[0.2em] text-muted-foreground uppercase transition-colors duration-400 group-hover:text-primary/80">
                      // {exp.period}
                    </p>
                  </div>

                  <!-- Location & Type Badge -->
                  <div class="mt-8 hidden flex-col gap-3 md:flex">
                    <div class="flex items-center gap-2">
                      <span class="h-1.5 w-1.5 border border-primary/50" />
                      <span class="font-mono text-[9px] tracking-[0.1em] text-muted-foreground uppercase">
                        {exp.location}
                      </span>
                    </div>
                    <div class="inline-flex w-fit items-center border border-primary/20 bg-primary/5 px-2 py-1 font-mono text-[9px] font-bold tracking-widest text-primary uppercase transition-colors duration-400 group-hover:border-primary/40 group-hover:bg-primary/10">
                      {exp.type}
                    </div>
                  </div>

                  <!-- Stats -->
                  <div class="mt-auto hidden flex-col gap-5 border-t border-border pt-6 md:flex">
                    {exp.stats.map((stat) => (
                      <div class="flex flex-col gap-1">
                        <div class="text-xl font-black tracking-tighter text-foreground transition-colors duration-400 group-hover:text-primary">
                          {stat.value}
                        </div>
                        <div class="font-mono text-[8px] font-semibold tracking-[0.15em] text-muted-foreground uppercase transition-colors duration-400 group-hover:text-primary/70">
                          {stat.label}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- Right Column: Content -->
                <div class="flex w-full flex-col p-6 md:w-3/4 md:p-8 lg:w-[75%] xl:w-[78%]">
                  <!-- Company & Role -->
                  <div class="mb-8 flex flex-col gap-5">
                    <div class="inline-block w-fit border border-border bg-card px-3 py-1 font-mono text-[10px] font-bold tracking-[0.2em] text-foreground uppercase transition-colors duration-400 group-hover:border-primary/40 group-hover:text-primary">
                      {exp.company}
                    </div>
                    <h4 class="text-4xl font-black leading-[0.85] text-foreground uppercase transition-colors duration-400 group-hover:text-foreground/90 md:text-5xl lg:text-[5.5rem] xl:text-[6.5rem]">
                      {exp.title.map((line) => (
                        <span class="block origin-left scale-x-[1.1] pr-[10%] sm:scale-x-[1.15] lg:scale-x-[1.2]">
                          {line}
                        </span>
                      ))}
                    </h4>
                  </div>

                  <!-- Description Grid -->
                  <div class="mt-6 grid grid-cols-1 gap-10 md:mt-12 lg:grid-cols-2 lg:gap-12 xl:gap-20">
                    <div class="flex flex-col gap-6">
                      <div class="relative pl-4">
                        <div class="absolute bottom-0 left-0 top-1 w-px bg-primary/30 transition-colors duration-400 group-hover:bg-primary" />
                        <p class="text-sm leading-relaxed text-muted-foreground">
                          {exp.description}
                        </p>
                      </div>

                      <ul class="flex flex-col gap-3">
                        {exp.highlights.map((h) => (
                          <li class="flex items-start gap-3">
                            <span class="mt-1 flex h-3 w-3 shrink-0 items-center justify-center border border-primary/30 bg-primary/10 text-[8px] text-primary transition-colors duration-400 group-hover:border-primary/60 group-hover:bg-primary/20">
                              +
                            </span>
                            <span class="text-xs leading-relaxed text-muted-foreground transition-colors duration-400 group-hover:text-foreground/80">
                              {h}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>

                    <div class="flex flex-col gap-8">
                      <!-- Tech Stack -->
                      <div class="flex flex-col gap-4">
                        <h5 class="font-mono text-[10px] font-bold tracking-[0.2em] text-foreground uppercase">
                          // TECH_STACK
                        </h5>
                        <div class="flex flex-wrap gap-2">
                          {exp.technologies.map((tech) => (
                            <span class="border border-border bg-muted/30 px-2 py-1 font-mono text-[9px] font-bold tracking-[0.1em] text-foreground uppercase transition-colors duration-300 hover:border-primary/50 hover:bg-primary/10 hover:text-primary">
                              {tech}
                            </span>
                          ))}
                        </div>
                      </div>

                      <!-- Key Takeaway -->
                      <div class="border-l-[1.5px] border-border pl-4 transition-colors duration-400 group-hover:border-primary/40">
                        <h5 class="mb-2 font-mono text-[9px] font-bold tracking-[0.2em] text-primary uppercase">
                          [ KEY_TAKEAWAY ]
                        </h5>
                        <p class="text-xs leading-relaxed text-muted-foreground italic">
                          "{exp.learned}"
                        </p>
                      </div>

                      <!-- Mobile-only stats -->
                      <div class="flex flex-wrap gap-6 border-t border-border pt-6 md:hidden">
                        {exp.stats.map((stat) => (
                          <div class="flex flex-col gap-1">
                            <div class="text-xl font-black tracking-tighter text-foreground transition-colors duration-400 group-hover:text-primary">
                              {stat.value}
                            </div>
                            <div class="font-mono text-[8px] font-semibold tracking-[0.15em] text-muted-foreground uppercase transition-colors duration-400 group-hover:text-primary/70">
                              {stat.label}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="border-x border-b border-border bg-card">
      <div class="relative flex flex-col items-center justify-between gap-6 overflow-hidden px-8 py-8 sm:flex-row">
        <!-- Scanline overlay -->
        <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(0_0_0/0.015)_2px,oklch(0_0_0/0.015)_4px)] opacity-50 dark:bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(1_1_1/0.015)_2px,oklch(1_1_1/0.015)_4px)]" />
        
        <div class="relative z-10 flex items-center gap-4 border border-border bg-background px-4 py-2 shadow-sm">
          <div class="relative flex h-2 w-2 items-center justify-center">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          </div>
          <p class="font-mono text-[10px] font-semibold tracking-[0.2em] text-muted-foreground uppercase">
            System Online / Open to Opportunities
          </p>
        </div>

        <a href="#contact" class="group relative z-10 inline-flex items-center gap-3 border border-primary/30 bg-primary/10 px-6 py-3 font-mono text-[11px] font-bold tracking-[0.2em] text-primary uppercase transition-all duration-300 hover:border-primary hover:bg-primary hover:text-primary-foreground hover:shadow-[0_0_20px_oklch(var(--primary)/0.3)]">
          <span>Initialize Contact</span>
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

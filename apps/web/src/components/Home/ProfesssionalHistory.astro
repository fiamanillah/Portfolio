---
const experiences = [
  {
    year: "2023",
    period: "PRESENT // 18 MO",
    company: "TechCorp Inc.",
    role: "SENIOR SOFTWARE ENGINEER",
    title: ["SENIOR SOFTWARE", "ENGINEER"],
    location: "San Francisco, CA · Remote",
    type: "Full-Time",
    description:
      "Led the architectural redesign of the core platform, increasing system throughput by 40%. Owned end-to-end delivery of three major product releases and established engineering best practices adopted company-wide.",
    highlights: [
      "Reduced API latency by 40% via caching & query optimization",
      "Mentored 4 junior engineers through structured growth plans",
      "Shipped 3 major releases with zero critical production incidents",
      "Architected microservices migration from monolith",
    ],
    technologies: ["TypeScript", "React", "Node.js", "AWS", "PostgreSQL", "Redis", "Docker", "GraphQL"],
    stats: [
      { label: "Performance Gain", value: "40%" },
      { label: "Engineers Mentored", value: "4" },
      { label: "Releases Shipped", value: "3" },
    ],
    learned: "Learned how to balance technical debt reduction with feature velocity in a high-growth environment.",
  },
  {
    year: "2021",
    period: "2023 // 24 MO",
    company: "DevStudio Ltd.",
    role: "FULL STACK DEVELOPER",
    title: ["FULL STACK", "DEVELOPER"],
    location: "New York, NY · Hybrid",
    type: "Full-Time",
    description:
      "Built and maintained production-grade web applications serving 200k+ monthly users. Designed and implemented CI/CD pipelines that cut deployment time by 60%, and led the migration to a modern React frontend.",
    highlights: [
      "Cut deployment pipeline time from 45 min → 18 min",
      "Migrated legacy jQuery app to React 18 with zero downtime",
      "Integrated Stripe payments processing $2M+ monthly",
      "Built internal analytics dashboard used by 3 teams",
    ],
    technologies: ["JavaScript", "Next.js", "PostgreSQL", "Stripe", "GitHub Actions", "Vercel", "Prisma", "Tailwind"],
    stats: [
      { label: "Deployment Speedup", value: "60%" },
      { label: "Monthly Users", value: "200K" },
      { label: "Revenue Processed", value: "$2M+" },
    ],
    learned: "Mastered the art of incremental migrations — rewriting systems in production without disrupting users.",
  },
  {
    year: "2020",
    period: "2021 // 12 MO",
    company: "LaunchPad Startup",
    role: "JUNIOR DEVELOPER",
    title: ["JUNIOR", "DEVELOPER"],
    location: "Austin, TX · On-Site",
    type: "Full-Time",
    description:
      "Contributed to a fast-moving startup building a SaaS product for the EdTech space. Delivered responsive UI components, collaborated closely with designers, and contributed to 2 open-source libraries.",
    highlights: [
      "Shipped 20+ reusable UI components to the design system",
      "Contributed to 2 open-source Vue.js plugins (800+ GitHub stars)",
      "Reduced bundle size by 35% through code splitting",
      "Achieved 95+ Lighthouse score across all landing pages",
    ],
    technologies: ["HTML/CSS", "Vue.js", "Firebase", "Figma", "Webpack", "Jest", "Sass", "PWA"],
    stats: [
      { label: "Components Built", value: "20+" },
      { label: "Bundle Size Reduction", value: "35%" },
      { label: "Lighthouse Score", value: "95+" },
    ],
    learned: "Developed a deep appreciation for design systems and how great component architecture scales with the product.",
  },
]

const totalYears = 5
const totalCompanies = experiences.length
const totalTech = [...new Set(experiences.flatMap((e) => e.technologies))].length
---

<section
  data-grid-cross
  class="relative container mx-auto flex items-center justify-center overflow-hidden py-px"
>
  <div class="w-full">
    <div class="bg-background/40 shadow-sm backdrop-blur-3xl">
      <!-- Top Header Section -->
      <div class="border-b border-border text-center">
        <p class="mb-4 pt-6 text-[10px] tracking-[0.2em] text-muted-foreground uppercase">
          A brief overview of my professional journey, highlighting key roles,
          projects, and achievements that have shaped my career in software
          development.
        </p>
        <h1 class="mb-4 font-black tracking-tighter text-foreground italic">
          Professional <span class="font-bold text-primary">History</span>
        </h1>
        <p class="mb-6 text-[11px] font-semibold tracking-[0.15em] text-foreground uppercase">
          The places I've worked, the projects I've built, and the impact I've made
        </p>

        <!-- Summary Stats Bar -->
        <div class="border-t border-border grid grid-cols-3 divide-x divide-border">
          <div class="py-5 flex flex-col items-center gap-1 group">
            <span class="text-3xl font-black tracking-tighter text-primary tabular-nums">{totalYears}+</span>
            <span class="text-[9px] tracking-[0.2em] uppercase text-muted-foreground font-semibold">Years Experience</span>
          </div>
          <div class="py-5 flex flex-col items-center gap-1 group">
            <span class="text-3xl font-black tracking-tighter text-primary tabular-nums">{totalCompanies}</span>
            <span class="text-[9px] tracking-[0.2em] uppercase text-muted-foreground font-semibold">Companies</span>
          </div>
          <div class="py-5 flex flex-col items-center gap-1 group">
            <span class="text-3xl font-black tracking-tighter text-primary tabular-nums">{totalTech}+</span>
            <span class="text-[9px] tracking-[0.2em] uppercase text-muted-foreground font-semibold">Technologies</span>
          </div>
        </div>
      </div>
    </div>

    <div class="flex w-full border border-border">
      <!-- Vertical Label -->
      <div class="flex w-20 items-center justify-center px-4 py-8 text-5xl font-semibold text-muted-foreground border-r border-border">
        <h2 class="inline-block origin-center -rotate-90 whitespace-nowrap">
          Track Record
        </h2>
      </div>

      <!-- Grid Background -->
      <div
        class="relative w-full font-sans bg-[linear-gradient(rgba(128,128,128,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(128,128,128,0.08)_1px,transparent_1px)] bg-[length:40px_40px]"
      >
        <div class="mx-auto border border-border bg-transparent">
          {
            experiences.map((exp, index) => (
              <div class={`exp-entry flex flex-col ${index !== experiences.length - 1 ? "border-b" : ""} border-border md:flex-row`}>
                {/* Left Column: Dates + Stats */}
                <div class="flex w-full flex-row justify-between border-b border-border md:w-1/4 md:flex-col md:border-r md:border-b-0 md:p-8 lg:w-[22%]">
                  <h2 class="text-6xl font-black tracking-tighter text-foreground md:text-7xl">
                    {exp.year}
                  </h2>
                  <p class="mt-auto pt-8 text-[10px] font-bold tracking-widest uppercase text-muted-foreground md:text-xs">
                    {exp.period}
                  </p>

                  {/* Achievement stats */}
                  <div class="hidden md:flex flex-col gap-3 mt-8 pt-8 border-t border-border">
                    {exp.stats.map((stat) => (
                      <div>
                        <div class="text-xl font-black tracking-tighter text-primary">{stat.value}</div>
                        <div class="text-[9px] tracking-[0.15em] uppercase text-muted-foreground font-semibold leading-tight">{stat.label}</div>
                      </div>
                    ))}
                  </div>

                  {/* Location + Type badge */}
                  <div class="hidden md:flex flex-col gap-2 mt-6">
                    <div class="flex items-center gap-1.5">
                      <svg class="w-2.5 h-2.5 text-muted-foreground shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <span class="text-[9px] tracking-wider text-muted-foreground uppercase">{exp.location}</span>
                    </div>
                    <div class="inline-flex w-fit items-center border border-primary/30 bg-primary/5 px-2 py-0.5 text-[9px] font-bold tracking-widest uppercase text-primary">
                      {exp.type}
                    </div>
                  </div>
                </div>

                {/* Right Column: Content */}
                <div class="flex w-full flex-col p-6 md:w-3/4 md:p-8 lg:w-[78%]">
                  {/* Company badge + title */}
                  <div class="mb-4">
                    <div class="mb-4 inline-block border-2 border-border px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase text-foreground md:text-xs">
                      {exp.company}
                    </div>
                    <h3 class="text-5xl leading-[0.85] font-black uppercase text-foreground md:text-7xl lg:text-[5.5rem]">
                      {exp.title.map((line, i) => (
                        <>
                          <span class="inline-block scale-x-[1.3] origin-left pr-[20%]">
                            {line}
                          </span>
                          {i < exp.title.length - 1 && <br />}
                        </>
                      ))}
                    </h3>
                  </div>

                  {/* Description + Highlights grid */}
                  <div class="mt-12 grid grid-cols-1 gap-8 md:mt-24 md:grid-cols-2 md:gap-12 lg:gap-24">
                    <div>
                      <p class="mb-4 text-[10px] font-bold text-foreground md:text-xs">&gt;&gt;</p>
                      <p class="text-[10px] leading-relaxed font-medium text-foreground md:text-xs">
                        {exp.description}
                      </p>

                      {/* Key highlights */}
                      <ul class="mt-6 flex flex-col gap-2">
                        {exp.highlights.map((h) => (
                          <li class="flex items-start gap-2">
                            <span class="mt-px text-primary text-[10px] leading-none font-black shrink-0">▸</span>
                            <span class="text-[10px] leading-relaxed text-muted-foreground font-medium">{h}</span>
                          </li>
                        ))}
                      </ul>
                    </div>

                    <div class="flex flex-col gap-8">
                      {/* Technologies */}
                      <div>
                        <p class="mb-3 text-[10px] font-bold text-foreground md:text-xs">&gt;&gt; STACK</p>
                        <div class="flex flex-wrap gap-1.5">
                          {exp.technologies.map((tech) => (
                            <span class="inline-flex items-center border border-border bg-muted/40 px-2 py-0.5 text-[9px] font-bold tracking-wider uppercase text-foreground hover:border-primary/50 hover:text-primary transition-colors duration-200">
                              {tech}
                            </span>
                          ))}
                        </div>
                      </div>

                      {/* What I learned */}
                      <div class="border-l-2 border-primary/40 pl-4">
                        <p class="mb-2 text-[9px] font-bold tracking-[0.2em] uppercase text-primary">KEY TAKEAWAY</p>
                        <p class="text-[10px] leading-relaxed font-medium text-muted-foreground italic">
                          "{exp.learned}"
                        </p>
                      </div>

                      {/* Mobile-only stats */}
                      <div class="flex gap-6 md:hidden">
                        {exp.stats.map((stat) => (
                          <div>
                            <div class="text-xl font-black tracking-tighter text-primary">{stat.value}</div>
                            <div class="text-[9px] tracking-[0.15em] uppercase text-muted-foreground font-semibold leading-tight">{stat.label}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Bottom CTA strip -->
        <div class="border-t border-border flex flex-col sm:flex-row items-center justify-between px-8 py-6 gap-4">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
            <p class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground font-semibold">
              Currently open to new opportunities
            </p>
          </div>
          <a
            href="#contact"
            class="group inline-flex items-center gap-2 border border-primary/40 bg-primary/5 px-5 py-2 text-[10px] font-bold tracking-[0.2em] uppercase text-primary transition-all duration-200 hover:bg-primary hover:text-primary-foreground hover:border-primary"
          >
            Get In Touch
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

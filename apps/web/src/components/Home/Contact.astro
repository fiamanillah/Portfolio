---
import {
  GithubIcon,
  Linkedin02Icon,
  Facebook02Icon,
} from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"
import { Input } from "@workspace/ui/components/input"
import { Textarea } from "@workspace/ui/components/textarea"
import { Icon } from "astro-icon/components"
---

<style>
  /* Left-border hover accent on contact info rows */
  .contact-info-row {
    border-left: 2px solid transparent;
    padding-left: 1rem;
    transition:
      border-color 200ms ease,
      background 200ms ease;
  }
  .contact-info-row:hover {
    border-left-color: oklch(var(--primary) / 70%);
    background: oklch(var(--primary) / 4%);
  }

  /* Form field focus-within label lift */
  .field-group:focus-within label {
    color: oklch(var(--primary));
  }

  /* Subtle shimmer on submit hover */
  @keyframes shimmer-x {
    0% {
      background-position: -200% center;
    }
    100% {
      background-position: 200% center;
    }
  }
  .btn-shimmer:hover {
    animation: shimmer-x 1.4s ease infinite;
    background-image: linear-gradient(
      105deg,
      oklch(var(--primary)) 0%,
      oklch(var(--primary) / 85%) 45%,
      oklch(var(--primary)) 55%,
      oklch(var(--primary)) 100%
    );
    background-size: 200% auto;
  }
</style>

<section
  id="contact"
  class="relative z-10 container mx-auto overflow-hidden"
  data-grid-cross
>
  <!-- ── Section Header ─────────────────────────────────────────── -->
  <div class="relative overflow-hidden border-b border-border text-center">
    <!-- Diagonal stripe background -->
    <div
      class="diagonal-stripes pointer-events-none absolute inset-0 z-10 bg-background"
      aria-hidden="true"
    >
    </div>

    <!-- Ambient glow -->
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div
        class="absolute top-1/2 left-1/2 h-40 w-80 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[80px]"
      >
      </div>
    </div>

    <div class="relative z-10 py-8">
      <p class="section-label mb-4 pt-6">
        Open to opportunities · Remote friendly
      </p>
      <h2
        class="section-title mb-4 text-foreground"
        style="font-style: normal;"
      >
        Get In <span class="text-primary">Touch</span>
      </h2>
      <div class="accent-bar mx-auto mb-6 w-48"></div>
    </div>
  </div>

  <!-- ── Main Content ───────────────────────────────────────────── -->
  <div class="grid bg-card lg:grid-cols-[1fr_1.25fr]">
    <!-- Left Column: Info & Context -->
    <div
      class="flex flex-col justify-between border-b border-border p-8 md:p-10 lg:border-r lg:border-b-0"
    >
      <div class="flex flex-col gap-8">
        <!-- Editorial statement -->
        <div class="space-y-4">
          <p
            class="text-2xl leading-[1.15] font-bold tracking-tight text-foreground md:text-3xl"
          >
            Got a project in mind?<br />
            <span class="text-primary">Let's make it happen.</span>
          </p>
          <p class="max-w-[42ch] text-sm leading-relaxed text-muted-foreground">
            Whether it's a full-stack application, backend architecture, or
            cloud infrastructure — I'm open to freelance work, full-time roles,
            and interesting collaborations.
          </p>
        </div>

        <!-- Contact details (info + socials unified) -->
        <div class="flex flex-col gap-1 border-t border-border pt-6">
          <!-- Email -->
          <a
            href="mailto:fiamanillah1@gmail.com"
            class="contact-info-row group flex items-center gap-4 py-3 no-underline"
          >
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-200 group-hover:border-primary/40 group-hover:bg-primary/10 group-hover:text-primary"
            >
              <Icon name="mdi:email-outline" class="size-4" />
            </div>
            <div>
              <p
                class="font-mono text-[10px] tracking-[0.14em] text-muted-foreground uppercase"
              >
                Email
              </p>
              <p
                class="text-sm font-semibold text-foreground transition-colors group-hover:text-primary"
              >
                fiamanillah1@gmail.com
              </p>
            </div>
          </a>

          <!-- Response time -->
          <div class="contact-info-row flex items-center gap-4 py-3">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-background text-muted-foreground"
            >
              <Icon name="mdi:clock-outline" class="size-4" />
            </div>
            <div>
              <p
                class="font-mono text-[10px] tracking-[0.14em] text-muted-foreground uppercase"
              >
                Response Time
              </p>
              <p class="text-sm font-semibold text-foreground">
                Within 24 hours
              </p>
            </div>
          </div>

          <!-- Social links — same row pattern as above -->
          <div class="contact-info-row flex items-center gap-4 py-3">
            <div class="flex flex-col gap-2">
              <p
                class="font-mono text-[10px] tracking-[0.14em] text-muted-foreground uppercase"
              >
                Find me on
              </p>
              <div class="flex items-center gap-2">
                {
                  [
                    {
                      href: "https://github.com/fiamanillah",
                      label: "GitHub",
                      icon: GithubIcon,
                    },
                    {
                      href: "https://linkedin.com/in/fiamanillah",
                      label: "LinkedIn",
                      icon: Linkedin02Icon,
                    },
                    {
                      href: "https://facebook.com/fiamanillah",
                      label: "Facebook",
                      icon: Facebook02Icon,
                    },
                  ].map(({ href, label, icon }) => (
                    <a
                      href={href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={label}
                      class="inline-flex h-9 w-9 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-200 hover:border-primary/50 hover:bg-primary/10 hover:text-primary hover:shadow-[0_0_10px_oklch(var(--primary)/0.2)]"
                    >
                      <HugeiconsIcon
                        icon={icon}
                        className="size-4"
                        aria-hidden="true"
                      />
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Form -->
    <div class="relative bg-background/50 p-8 md:p-10">
      <!-- Corner brackets -->
      <div
        class="pointer-events-none absolute top-3 left-3 h-5 w-5 border-t-[1.5px] border-l-[1.5px] border-primary/30"
      >
      </div>
      <div
        class="pointer-events-none absolute top-3 right-3 h-5 w-5 border-t-[1.5px] border-r-[1.5px] border-primary/30"
      >
      </div>
      <div
        class="pointer-events-none absolute bottom-3 left-3 h-5 w-5 border-b-[1.5px] border-l-[1.5px] border-primary/30"
      >
      </div>
      <div
        class="pointer-events-none absolute right-3 bottom-3 h-5 w-5 border-r-[1.5px] border-b-[1.5px] border-primary/30"
      >
      </div>

      <!-- Form header row -->
      <div
        class="mb-6 flex items-center justify-between border-b border-border pb-4"
      >
        <span
          class="font-mono text-xs font-bold tracking-[0.12em] text-foreground uppercase"
        >
          Send a Message
        </span>
        <div
          class="flex items-center gap-2 border border-border bg-background px-2.5 py-1"
        >
          <Icon name="mdi:lock-outline" class="size-3 text-primary/50" />
          <span
            class="font-mono text-[10px] tracking-[0.1em] text-muted-foreground uppercase"
          >
            Secure
          </span>
        </div>
      </div>

      <!-- Form -->
      <form id="contact-form" class="flex flex-col gap-5">
        <!-- Name + Email row -->
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <!-- Name -->
          <div class="field-group flex flex-col gap-2">
            <label
              for="contact-name"
              class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase transition-colors"
            >
              Full Name <span class="text-primary">*</span>
            </label>
            <Input
              type="text"
              id="contact-name"
              name="name"
              required
              placeholder="Your name"
              className="h-11 w-full rounded-none border border-border bg-background/60 px-3 font-mono text-sm text-foreground transition-all duration-200 outline-none placeholder:text-muted-foreground/40 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:shadow-[0_0_0_1px_oklch(var(--primary)/30%)] focus-visible:ring-0"
            />
          </div>

          <!-- Email -->
          <div class="field-group flex flex-col gap-2">
            <label
              for="contact-email"
              class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase transition-colors"
            >
              Email Address <span class="text-primary">*</span>
            </label>
            <Input
              type="email"
              id="contact-email"
              name="email"
              required
              placeholder="you@example.com"
              className="h-11 w-full rounded-none border border-border bg-background/60 px-3 font-mono text-sm text-foreground transition-all duration-200 outline-none placeholder:text-muted-foreground/40 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:shadow-[0_0_0_1px_oklch(var(--primary)/30%)] focus-visible:ring-0"
            />
          </div>
        </div>

        <!-- Subject -->
        <div class="field-group flex flex-col gap-2">
          <label
            for="contact-subject"
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase transition-colors"
          >
            Subject
          </label>
          <Input
            type="text"
            id="contact-subject"
            name="subject"
            placeholder="What's this about?"
            className="h-11 w-full rounded-none border border-border bg-background/60 px-3 font-mono text-sm text-foreground transition-all duration-200 outline-none placeholder:text-muted-foreground/40 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:shadow-[0_0_0_1px_oklch(var(--primary)/30%)] focus-visible:ring-0"
          />
        </div>

        <!-- Message -->
        <div class="field-group flex flex-col gap-2">
          <label
            for="contact-message"
            class="font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase transition-colors"
          >
            Message <span class="text-primary">*</span>
          </label>
          <Textarea
            id="contact-message"
            name="message"
            required
            rows={5}
            placeholder="Tell me about your project, timeline, and budget..."
            className="min-h-[7.5rem] w-full resize-none rounded-none border border-border bg-background/60 p-3 font-mono text-sm text-foreground transition-all duration-200 outline-none placeholder:text-muted-foreground/40 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:shadow-[0_0_0_1px_oklch(var(--primary)/30%)] focus-visible:ring-0"
          />
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          id="contact-submit"
          class="btn-shimmer group/btn relative mt-2 inline-flex w-full items-center justify-center gap-3 border border-primary bg-primary px-6 py-3.5 font-mono text-[0.75rem] font-bold tracking-[0.15em] text-primary-foreground uppercase transition-all duration-300 hover:shadow-[0_0_24px_oklch(var(--primary)/0.4)] disabled:cursor-not-allowed disabled:opacity-60"
        >
          <span
            id="contact-submit-text"
            class="flex items-center gap-3 transition-transform duration-200"
          >
            Send Message
            <svg
              class="size-4 transition-transform duration-200 group-hover/btn:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </button>
      </form>

      <!-- Privacy note -->
      <p
        class="mt-4 font-mono text-[10px] tracking-wide text-muted-foreground/60 uppercase"
      >
        Your information is kept private and never shared.
      </p>
    </div>
  </div>

  <!-- ── Bottom Status Bar ───────────────────────────────────────── -->
  <div
    class="relative flex flex-col items-center justify-between gap-3 overflow-hidden border-t border-border bg-card px-6 py-4 md:flex-row"
  >
    <!-- Shimmer line -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-primary/30 to-transparent opacity-60"
      aria-hidden="true"
    >
    </div>

    <span
      class="font-mono text-xs tracking-[0.1em] text-muted-foreground uppercase"
    >
      Fi Amanillah · Full-Stack Developer · Dhaka, BD
    </span>

    <div class="flex items-center gap-2">
      <span class="relative flex h-1.5 w-1.5">
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
        ></span>
        <span
          class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"
        ></span>
      </span>
      <span
        class="font-mono text-xs tracking-[0.1em] text-muted-foreground uppercase"
      >
        Open to remote opportunities
      </span>
    </div>
  </div>
</section>

<script>
  function setupContactForm() {
    const form = document.getElementById(
      "contact-form"
    ) as HTMLFormElement | null
    const submitBtn = document.getElementById(
      "contact-submit"
    ) as HTMLButtonElement | null
    const submitText = document.getElementById("contact-submit-text")

    if (!form || !submitBtn || !submitText) return

    form.addEventListener("submit", async (e) => {
      e.preventDefault()

      const originalHTML = submitText.innerHTML
      submitBtn.disabled = true
      submitText.innerHTML = `<span class="animate-pulse">Sending...</span>`

      await new Promise((resolve) => setTimeout(resolve, 2000))

      submitText.innerHTML = `
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Message Sent!
      `
      submitBtn.classList.remove("bg-primary", "border-primary")
      submitBtn.classList.add("bg-emerald-600", "border-emerald-600")

      setTimeout(() => {
        submitText.innerHTML = originalHTML
        submitBtn.classList.add("bg-primary", "border-primary")
        submitBtn.classList.remove("bg-emerald-600", "border-emerald-600")
        submitBtn.disabled = false
        form.reset()
      }, 3000)
    })
  }

  document.addEventListener("astro:page-load", setupContactForm)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupContactForm)
  } else {
    setupContactForm()
  }
</script>

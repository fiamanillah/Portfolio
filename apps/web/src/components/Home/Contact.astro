---
import {
  GithubIcon,
  Linkedin02Icon,
  Facebook02Icon,
} from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"
import { Button } from "@workspace/ui/components/button"
import { Input } from "@workspace/ui/components/input"
import { Textarea } from "@workspace/ui/components/textarea"
import { Icon } from "astro-icon/components"
---

<section id="contact" class="relative z-10 container mx-auto flex items-center justify-center overflow-hidden py-px" data-grid-cross>
  <div class="w-full">
    
    <!-- Main wrapper with border and brackets -->
    <div class="group relative overflow-hidden bg-card">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(120%_140%_at_50%_0%,oklch(var(--primary)/0.03),transparent_55%)]" />
      <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(0_0_0/0.015)_2px,oklch(0_0_0/0.015)_4px)] opacity-50 dark:bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,oklch(1_1_1/0.015)_2px,oklch(1_1_1/0.015)_4px)]" />

      <div class="grid relative z-10 lg:grid-cols-2">
        <!-- Left Column: Copy & Contact Info -->
        <div class="flex flex-col justify-between border-b border-border p-8 md:p-12 lg:border-b-0 lg:border-r lg:p-16">
          <!-- Header -->
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 border border-primary/20 bg-primary/10 px-3 py-1">
              <span class="h-1.5 w-1.5 animate-pulse bg-primary shadow-[0_0_8px_oklch(var(--primary)/0.8)]" />
              <span class="font-mono text-[10px] tracking-[0.22em] text-primary uppercase">
                Module // Transmission_03
              </span>
            </div>

            <h2 class="text-4xl font-black tracking-tighter text-foreground sm:text-5xl lg:text-6xl">
              Establish<br />
              <span class="text-primary transition-all duration-400 group-hover:drop-shadow-[0_0_12px_oklch(var(--primary)/0.4)]">Connection</span><span class="animate-pulse text-primary">_</span>
            </h2>

            <div class="relative pl-4">
              <div class="absolute bottom-0 left-0 top-1 w-px bg-primary/30 transition-colors duration-400 group-hover:bg-primary" />
              <p class="max-w-[42ch] text-sm leading-relaxed text-muted-foreground">
                The secure channel is open. Transmit your project directives or
                inquiries. All packets are encrypted.
              </p>
            </div>
          </div>

          <!-- Contact Details -->
          <div class="mt-12 flex flex-col gap-6 border-t border-border pt-8">
            <!-- Email -->
            <div class="group/item flex items-center gap-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-300 group-hover/item:border-primary/50 group-hover/item:bg-primary/10 group-hover/item:text-primary group-hover/item:shadow-[0_0_12px_oklch(var(--primary)/0.2)]">
                <Icon name="mdi:email-outline" class="size-5" />
              </div>
              <div class="flex flex-col gap-1.5">
                <p class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors duration-300 group-hover/item:text-primary/70">
                  Secure Mail
                </p>
                <a href="mailto:fiamanillah1@gmail.com" class="font-mono text-xs sm:text-sm font-bold tracking-tight text-foreground transition-colors duration-300 hover:text-primary group-hover/item:text-primary">
                  fiamanillah1@gmail.com
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="group/item flex items-center gap-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-300 group-hover/item:border-primary/50 group-hover/item:bg-primary/10 group-hover/item:text-primary group-hover/item:shadow-[0_0_12px_oklch(var(--primary)/0.2)]">
                <Icon name="mdi:map-marker-outline" class="size-5" />
              </div>
              <div class="flex flex-col gap-1.5">
                <p class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors duration-300 group-hover/item:text-primary/70">
                  Global Base
                </p>
                <p class="font-mono text-xs sm:text-sm font-bold tracking-tight text-foreground transition-colors duration-300 group-hover/item:text-primary">
                  Mirpur, Dhaka // Node_01
                </p>
              </div>
            </div>

            <!-- Social Uplink -->
            <div class="group/item flex items-center gap-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-300 group-hover/item:border-primary/50 group-hover/item:bg-primary/10 group-hover/item:text-primary group-hover/item:shadow-[0_0_12px_oklch(var(--primary)/0.2)]">
                <Icon name="mdi:share-variant-outline" class="size-5" />
              </div>
              <div class="flex flex-col gap-1.5">
                <p class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors duration-300 group-hover/item:text-primary/70">
                  Social Uplink
                </p>
                <div class="mt-0.5 flex items-center gap-2">
                  {
                    [
                      {
                        href: "https://github.com/fiamanillah",
                        label: "GitHub",
                        icon: GithubIcon,
                      },
                      {
                        href: "https://linkedin.com/in/fiamanillah",
                        label: "LinkedIn",
                        icon: Linkedin02Icon,
                      },
                      {
                        href: "https://facebook.com/fiamanillah",
                        label: "Facebook",
                        icon: Facebook02Icon,
                      },
                    ].map(({ href, label, icon }) => (
                      <a
                        href={href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={label}
                        class="inline-flex h-8 w-8 items-center justify-center border border-border bg-background text-muted-foreground transition-all duration-200 hover:border-primary/50 hover:bg-primary/10 hover:text-primary hover:shadow-[0_0_8px_oklch(var(--primary)/0.2)]"
                      >
                        <HugeiconsIcon
                          icon={icon}
                          className="size-4"
                          aria-hidden="true"
                        />
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div class="relative flex flex-col justify-between bg-background/50 p-8 md:p-12 lg:p-16 backdrop-blur-sm">
          <!-- Inner Corner brackets -->
          <div class="pointer-events-none absolute left-0 top-0 h-2 w-2 border-l-[1.5px] border-t-[1.5px] border-primary/40" />
          <div class="pointer-events-none absolute right-0 top-0 h-2 w-2 border-r-[1.5px] border-t-[1.5px] border-primary/40" />

          <!-- Form Header -->
          <div class="mb-8 flex items-center justify-between border-b border-border pb-4">
            <span class="font-mono text-[10px] font-bold tracking-[0.2em] text-foreground uppercase">
              Transmission.V4
            </span>
            <div class="flex items-center gap-2 border border-border bg-background px-2 py-1">
              <span class="relative flex h-1.5 w-1.5 items-center justify-center">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
              </span>
              <span class="font-mono text-[8px] tracking-[0.15em] text-muted-foreground uppercase">
                Res_256_Active
              </span>
            </div>
          </div>

          <!-- Form -->
          <form id="contact-form" class="flex flex-col gap-6">
            <!-- Name Field -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-name"
                class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors focus-within:text-primary"
              >
                Ident_Name
              </label>
              <Input
                type="text"
                id="contact-name"
                name="name"
                placeholder="Ghost_User"
                className="h-11 w-full rounded-none border-x-0 border-t-0 border-b border-border bg-background/30 px-3 font-mono text-sm text-foreground transition-colors duration-200 outline-none placeholder:text-muted-foreground/30 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:ring-0"
              />
            </div>

            <!-- Email Field -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-email"
                class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors focus-within:text-primary"
              >
                Endpoint_Email
              </label>
              <Input
                type="email"
                id="contact-email"
                name="email"
                placeholder="user@domain.sys"
                className="h-11 w-full rounded-none border-x-0 border-t-0 border-b border-border bg-background/30 px-3 font-mono text-sm text-foreground transition-colors duration-200 outline-none placeholder:text-muted-foreground/30 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:ring-0"
              />
            </div>

            <!-- Message Field -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-message"
                class="font-mono text-[8px] tracking-[0.2em] text-muted-foreground uppercase transition-colors focus-within:text-primary"
              >
                Directive_Brief
              </label>
              <Textarea
                id="contact-message"
                name="message"
                rows={4}
                placeholder="Input_mission_parameters..."
                className="min-h-32 w-full resize-none rounded-none border-x-0 border-t-0 border-b border-border bg-background/30 p-3 font-mono text-sm text-foreground transition-colors duration-200 outline-none placeholder:text-muted-foreground/30 focus-visible:border-primary focus-visible:bg-primary/5 focus-visible:ring-0"
              />
            </div>

            <!-- Submit Button -->
            <button 
              type="submit" 
              id="contact-submit"
              class="group/btn relative mt-4 inline-flex w-full items-center justify-center gap-3 border border-primary/30 bg-primary/10 px-6 py-4 font-mono text-xs font-bold tracking-[0.2em] text-primary uppercase transition-all duration-300 hover:border-primary hover:bg-primary hover:text-primary-foreground hover:shadow-[0_0_20px_oklch(var(--primary)/0.3)]"
            >
              <span class="transition-transform duration-200 group-hover/btn:-translate-x-1">Transmit Signal</span>
              <span class="transition-transform duration-200 group-hover/btn:translate-x-1">⚡</span>
            </button>
          </form>

          <!-- Encryption Note -->
          <div class="mt-6 flex justify-end">
            <div class="inline-flex items-center gap-2 border border-border bg-background px-2 py-1">
              <Icon name="mdi:lock-outline" class="size-3 text-primary/50" />
              <span class="font-mono text-[8px] tracking-wider text-muted-foreground/60 uppercase">
                end-to-end encrypted
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Form submission handler -->
<script>
  function setupContactForm() {
    const form = document.getElementById(
      "contact-form"
    ) as HTMLFormElement | null
    const submitBtn = document.getElementById(
      "contact-submit"
    ) as HTMLButtonElement | null

    if (!form || !submitBtn) return

    form.addEventListener("submit", async (e) => {
      e.preventDefault()

      const originalText = submitBtn.innerHTML
      submitBtn.innerHTML = `
        <span class="animate-pulse">Transmitting...</span>
      `
      submitBtn.disabled = true

      // Simulate transmission delay
      await new Promise((resolve) => setTimeout(resolve, 2000))

      submitBtn.innerHTML = `
        <span class="text-primary-foreground">✓ Signal Received</span>
      `

      setTimeout(() => {
        submitBtn.innerHTML = originalText
        submitBtn.disabled = false
        form.reset()
      }, 3000)
    })
  }

  document.addEventListener("astro:page-load", setupContactForm)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupContactForm)
  } else {
    setupContactForm()
  }
</script>

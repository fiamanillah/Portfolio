---
import {
  Facebook02Icon,
  GithubIcon,
  Linkedin02Icon,
} from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"

const currentYear = new Date().getFullYear()

const socialLinks = [
  { label: "GitHub", href: "https://github.com", icon: "github" },
  { label: "LinkedIn", href: "https://linkedin.com", icon: "linkedin" },
  { label: "Twitter", href: "https://twitter.com", icon: "twitter" },
  { label: "Email", href: "mailto:hello@example.com", icon: "mail" },
]

const footerLinks = [
  {
    title: "Navigation",
    links: [
      { label: "Home", href: "/" },
      { label: "About", href: "/about" },
      { label: "Components", href: "/components" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", href: "/blog" },
      { label: "Projects", href: "/projects" },
      { label: "Resume", href: "/resume" },
      { label: "Sitemap", href: "/sitemap.xml" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Privacy Policy", href: "/privacy" },
      { label: "Terms of Service", href: "/terms" },
      { label: "Disclaimer", href: "/disclaimer" },
    ],
  },
]
---

<footer class="border-t border-border bg-background/40 backdrop-blur-sm">
  <div class="container mx-auto px-4 py-12">
    <!-- Footer Content Grid -->
    <div class="mb-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Section -->
      <div class="flex flex-col gap-4">
        <a
          href="/"
          class="flex w-fit items-center text-lg font-semibold tracking-tight text-foreground transition-colors hover:text-primary"
        >
          <img src="/logo1.svg" alt="Fi Amanillah Logo" class="mr-2 h-6 w-6" />
          Fi Amanillah
        </a>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Full-stack developer building beautiful and functional digital
          experiences.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          {
            [
              { href: "#", label: "GitHub", icon: GithubIcon },
              { href: "#", label: "LinkedIn", icon: Linkedin02Icon },
              { href: "#", label: "Facebook", icon: Facebook02Icon },
            ].map(({ href, label, icon }) => (
              <a
                href={href}
                aria-label={label}
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-border bg-background text-foreground transition hover:border-primary hover:bg-primary/10 focus:ring-2 focus:ring-primary/30 focus:outline-none"
              >
                <HugeiconsIcon
                  icon={icon}
                  className="size-5"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Footer Links Sections -->
      {
        footerLinks.map((section) => (
          <div class="flex flex-col gap-3">
            <h3 class="text-sm font-semibold text-foreground">
              {section.title}
            </h3>
            <ul class="m-0 flex list-none flex-col gap-2 p-0">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="rounded px-1 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:outline-none"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Divider -->
    <div class="border-t border-border"></div>

    <!-- Bottom Section -->
    <div
      class="flex flex-col gap-4 pt-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-xs text-muted-foreground">
        &copy; {currentYear} Fi Amanillah. All rights reserved.
      </p>
      <p class="text-xs text-muted-foreground">
        Built with <span class="text-primary">♥</span> using Astro & React
      </p>
    </div>
  </div>
</footer>

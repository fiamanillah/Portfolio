---
import { ThemeToggle } from "@/components/theme-toggle"

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/components", label: "Components" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
]
---

<nav
  aria-label="Primary"
  class="flex flex-col items-start gap-3 py-4 sm:flex-row sm:items-center sm:justify-between"
>
  <a
    href="/"
    class="text-lg font-semibold tracking-tight text-foreground transition-colors hover:text-primary"
  >
    <img
      src="/logo1.svg"
      alt="Fi Amanillah Logo"
      class="mr-2 inline h-6 w-6"
    />Fi Amanillah
  </a>

  <div class="flex w-full flex-wrap items-center gap-3 sm:w-auto sm:gap-4">
    <ul
      class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-medium text-muted-foreground"
    >
      {
        navLinks.map((link) => (
          <li class="m-0 list-none!">
            <a
              href={link.href}
              class="rounded-md px-2 py-1 transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:outline-none"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <ThemeToggle client:load />
  </div>
</nav>
